# Database (shared adv-os-db)
DATABASE_URL=postgresql://advos:YOUR_DB_PASSWORD@localhost:5433/blueprints_dev

# DeepSeek API
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Admin password for client portal
ADMIN_PASSWORD=change-me-to-something-secure

# Session secret
SESSION_SECRET=change-me-to-a-random-string

# Rate limit: max blueprint generations per IP per hour
RATE_LIMIT_PER_HOUR=5

# App URL
NEXT_PUBLIC_APP_URL=https://failfast.online
